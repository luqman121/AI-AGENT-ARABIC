{
  "name": "@wakil/artifacts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./file-artifacts": {
      "types": "./src/file-artifacts.ts",
      "default": "./dist/file-artifacts.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "storage:health": "node --env-file-if-exists=../../.env.local dist/health-check.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "@wakil/skills": "workspace:*",
    "docx": "9.7.1",
    "exceljs": "4.4.0",
    "fflate": "0.8.3",
    "pdf-parse": "1.1.1",
    "pdfkit": "0.17.2",
    "pptxgenjs": "4.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pdf-parse": "1.1.5",
    "@types/pdfkit": "0.17.3"
  }
}
