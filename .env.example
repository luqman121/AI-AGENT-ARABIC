# Runtime
NODE_ENV=
LOG_LEVEL=

# PostgreSQL (POSTGRES_* are used only by local/self-hosted Compose)
DATABASE_URL=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# Redis
REDIS_URL=

# Private Cloudflare R2 storage
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true

# Email
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# Auth.js
AUTH_SECRET=
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Worker and queue
WORKER_CONCURRENCY=
WORKER_HEALTH_PORT=

# Model routing (configure the selected provider key and model)
MODEL_PROVIDER=
MODEL_DEADLINE_MS=
MODEL_MAX_ATTEMPTS=
MODEL_MAX_COST_MICROS=
MODEL_MAX_DELTA_EVENTS=
MODEL_MAX_OUTPUT_CHARS=
MODEL_MAX_OUTPUT_TOKENS=
MODEL_INPUT_COST_MICROS_PER_MILLION_TOKENS=
MODEL_OUTPUT_COST_MICROS_PER_MILLION_TOKENS=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODEL=

# Static-site execution and Daytona sandbox
EXECUTION_MODEL_MAX_COST_MICROS=
EXECUTION_MODEL_MAX_HTML_BYTES=
EXECUTION_MODEL_MAX_OUTPUT_CHARS=
EXECUTION_MODEL_MAX_OUTPUT_TOKENS=
DAYTONA_API_KEY=
DAYTONA_API_URL=
DAYTONA_TARGET=
SANDBOX_COMMAND_TIMEOUT_SECONDS=
SANDBOX_MAX_DURATION_MS=
SANDBOX_TTL_MINUTES=
ARTIFACT_MAX_ZIP_BYTES=
