{
  "name": "@wakil/artifacts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "storage:health": "node --env-file-if-exists=../../.env.local dist/health-check.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.1090.0",
    "@aws-sdk/s3-request-presigner": "3.1090.0",
    "fflate": "0.8.3",
    "zod": "4.4.3"
  }
}
