{
  "name": "@wakil/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "vitest run --exclude src/**/*.integration.test.ts",
    "test:integration": "vitest run src/**/*.integration.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@wakil/agent-core": "workspace:*",
    "@wakil/artifacts": "workspace:*",
    "@wakil/db": "workspace:*",
    "@wakil/model-router": "workspace:*",
    "@wakil/sandbox": "workspace:*",
    "@wakil/shared": "workspace:*",
    "@wakil/skills": "workspace:*",
    "bullmq": "5.63.1",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "pino": "10.3.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4"
  }
}
