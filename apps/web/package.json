{
  "name": "@wakil/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.13.0 <23"
  },
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "eslint .",
    "start": "next start",
    "test": "vitest run --exclude tests/**/*.integration.test.ts",
    "test:a11y": "playwright test e2e/a11y.spec.ts",
    "test:e2e": "playwright test --grep-invert @visual",
    "test:e2e:visual": "playwright test --grep @visual",
    "test:integration": "vitest run tests/integration",
    "test:pwa": "playwright test e2e/pwa.spec.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "1.11.2",
    "@wakil/artifacts": "workspace:*",
    "@wakil/db": "workspace:*",
    "@wakil/shared": "workspace:*",
    "@wakil/ui": "workspace:*",
    "bullmq": "5.63.1",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.11.1",
    "lucide-react": "1.25.0",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.2",
    "@tailwindcss/postcss": "4.3.3",
    "@testcontainers/postgresql": "12.0.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/nodemailer": "7.0.4",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "jsdom": "27.4.0",
    "tailwindcss": "4.3.3",
    "testcontainers": "12.0.4"
  }
}
